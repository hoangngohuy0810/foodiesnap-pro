# GEMINI_API_KEYS: Danh sách các key cách nhau bằng dấu phẩy
# Để phục vụ tính năng xoay vòng (rotation) giảm thiểu Rate Limit 429
GEMINI_API_KEYS="MY_KEY_1,MY_KEY_2,MY_KEY_3"

# Có thể setup thêm biến cho firebase nếu chạy local
# GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"

# Cấu hình cổng cho backend local (Production Firebase sẽ tự cung cấp PORT)
PORT=8080

# (Tùy chọn) URL của API Backend để gọi từ Frontend lúc Dev
VITE_API_URL="http://localhost:8080/api/generate"

# ==========================================
# SEPAY PAYMENT GATEWAY
# ==========================================
# API Key cấu hình trong my.sepay.vn > Webhook Settings > Authentication
SEPAY_WEBHOOK_API_KEY="YOUR_SEPAY_WEBHOOK_API_KEY"

# Số tài khoản ngân hàng liên kết Sepay
SEPAY_BANK_ACCOUNT="YOUR_BANK_ACCOUNT_NUMBER"

# Mã ngân hàng (VD: MB, VCB, TCB, ACB, TP, BIDV, VTB...)
SEPAY_BANK_NAME="MB"

# ==========================================
# FIREBASE CLIENT SDK (Frontend)
# Lấy từ Firebase Console > Project Settings > Your Apps > Web App
# ==========================================
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="foodiesnap-pro.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="foodiesnap-pro"
VITE_FIREBASE_STORAGE_BUCKET="foodiesnap-pro.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
